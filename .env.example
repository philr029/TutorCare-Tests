# Security Diagnostic Toolkit API – Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to source control.

# ── Server ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
DEBUG=false

# ── Authentication ───────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Leave empty to disable authentication (development only).
API_KEYS=

# Set to true to disable authentication (local development).
AUTH_DISABLED=false

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute

# Redis connection string for distributed rate limiting.
# Uses in-memory storage when not set.
REDIS_URL=redis://localhost:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all.
CORS_ORIGINS=*

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true

# ── External API Keys ────────────────────────────────────────────────────────
# All optional – the toolkit works without them.
ABUSEIPDB_KEY=
VIRUSTOTAL_KEY=
NUMVERIFY_KEY=
TWILIO_SID=
TWILIO_TOKEN=

# ── Timeouts ─────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=10
